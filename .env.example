# Gemini API — used by all 5 agents
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Exa API — used by the AI News Hunter agent for web search
# Get from: https://dashboard.exa.ai/api-keys
EXA_API_KEY=your_exa_api_key_here

# Gmail — used by the Email Delivery agent to send the newsletter
# GMAIL_ADDRESS: your Gmail address
# GMAIL_APP_PASSWORD: 16-char app password (no spaces)
#   → myaccount.google.com → Security → 2-Step Verification → App Passwords
GMAIL_ADDRESS=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your16charapppassword
